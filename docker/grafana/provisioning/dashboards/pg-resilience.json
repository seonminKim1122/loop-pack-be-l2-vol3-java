{
  "title": "PG 외부 API 장애 대응 모니터링",
  "uid": "pg-resilience",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Tomcat Thread Pool",
      "description": "busy ≈ max 가 되면 서버 전체 장애",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "tomcat_threads_busy_threads{application=\"commerce-api\"}",
          "legendFormat": "busy"
        },
        {
          "expr": "tomcat_threads_current_threads{application=\"commerce-api\"}",
          "legendFormat": "current"
        },
        {
          "expr": "tomcat_threads_config_max_threads{application=\"commerce-api\"}",
          "legendFormat": "max"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "우리 API 응답 시간 분포 (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"commerce-api\"}[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"commerce-api\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"commerce-api\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "PG API 호출 시간 분포 (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_client_requests_seconds_bucket{application=\"commerce-api\"}[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_client_requests_seconds_bucket{application=\"commerce-api\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_client_requests_seconds_bucket{application=\"commerce-api\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "에러율 비교 (우리 API vs PG API)",
      "description": "client 에러율 > server 에러율이면 retry가 흡수한 것",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"commerce-api\", outcome=\"SERVER_ERROR\"}[1m]))",
          "legendFormat": "우리 API 5xx"
        },
        {
          "expr": "sum(rate(http_client_requests_seconds_count{application=\"commerce-api\", outcome=\"SERVER_ERROR\"}[1m]))",
          "legendFormat": "PG API 5xx"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ]
}
